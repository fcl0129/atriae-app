NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
# Required for intelligence endpoint: OPENAI_API_KEY + NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY

# App-level SMTP config used by Atriae product emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Curated digest provider selection (optional, defaults to mock for preview resilience)
DIGEST_CALENDAR_PROVIDER=mock
DIGEST_WEATHER_PROVIDER=mock
DIGEST_NEWS_PROVIDER=mock
DIGEST_RECOMMENDATION_PROVIDER=mock

# Optional provider credentials for live integrations
WEATHER_API_KEY=
NEWS_API_KEY=
TMDB_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LISTEN_NOTES_API_KEY=
